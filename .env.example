# Knowledge Base Platform — Environment Variables
# Copy to .env and fill in values for your environment.

# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                   # development | test | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_WORKERS=1
APP_SECRET_KEY=change-me-in-production

# ─── Paths ─────────────────────────────────────────────────────────────────────
DATA_DIR=./data
KNOWLEDGE_BASES_DIR=./data/knowledge_bases
MODELS_DIR=./data/models
LOGS_DIR=./data/logs
UPLOADS_DIR=./data/uploads

# ─── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=sentence_transformers   # sentence_transformers | ollama | openai_compatible
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DEVICE=cpu                        # cpu | cuda | mps

# ─── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_PROVIDER=qdrant                # qdrant | chroma | faiss
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─── Reranker ──────────────────────────────────────────────────────────────────
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu

# ─── OCR ───────────────────────────────────────────────────────────────────────
OCR_ENABLED=true
OCR_ENGINE=tesseract                        # tesseract | paddle
TESSERACT_CMD=/usr/bin/tesseract

# ─── VLM (Visual Language Model for figure descriptions) ───────────────────────
VLM_ENABLED=false
VLM_PROVIDER=ollama
VLM_MODEL=qwen2.5-vl:7b
OLLAMA_URL=http://localhost:11434

# ─── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=750
CHUNK_OVERLAP=100
CHUNK_MIN_SIZE=100

# ─── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RETRIEVAL_DENSE_WEIGHT=0.7
RETRIEVAL_BM25_WEIGHT=0.3
RETRIEVAL_FINAL_TOP_K=10

# ─── Observability ─────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/knowledge_base.db
